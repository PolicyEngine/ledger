        "groupby_dimension": "uk.firm.annual_turnover"
      },
      "measurement": {
        "entity": "firm",
        "concept": "uk.firm.count",
        "groupby_dimension": "uk.firm.annual_turnover"
      },
      "bindings": {
        "populace": {
          "metric_name": "ons/uk_business/enterprise_count/turnover_bands",
          "value_variable": "firm_count",
          "from_entity": "firm",
          "groupby_variable": "annual_turnover"
        },
        "axiom": {
          "metric_name": "ons/uk_business/enterprise_count/turnover_bands",
          "status": "pending",
          "value_rule": "uk.firm.count"
        }
      }
    },
    {
