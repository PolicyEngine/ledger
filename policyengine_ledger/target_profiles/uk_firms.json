          "metric_name": "hmrc/vat/registered_trader_count/turnover_bands",
          "value_variable": "firm_count",
          "from_entity": "firm",
          "groupby_variable": "annual_turnover",
          "filters": [
            {"variable": "vat_registered", "operator": "==", "value": true}
